rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DefaultCatchAll to close all unauthorized access
    match /{document=**} {
      allow read, write: if false;
    }

    // Global ID check helper
    function isValidDocId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Category schema validation helper
    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'icon', 'name'])
        && data.id is string && data.id.size() <= 100
        && data.icon is string && data.icon.size() <= 50
        && data.name is string && data.name.size() <= 200;
    }

    // Prompt schema validation helper
    function isValidPrompt(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'icon', 'url', 'description', 'tags'])
        && data.id is number
        && data.name is string && data.name.size() <= 300
        && data.category is string && data.category.size() <= 100
        && data.icon is string && data.icon.size() <= 100
        && data.url is string && data.url.size() <= 1500
        && data.description is string && data.description.size() <= 10000
        && data.tags is list;
    }

    // MedicalRecord schema validation helper
    function isValidMedicalRecord(data) {
      return data.keys().hasAll(['id', 'name', 'age', 'cat', 'note', 'symptoms', 'date'])
        && data.id is number
        && data.name is string && data.name.size() <= 300
        && data.age is string && data.age.size() <= 100
        && data.cat is string && data.cat.size() <= 100
        && data.note is string && data.note.size() <= 10000
        && data.symptoms is list
        && data.date is string && data.date.size() <= 100;
    }

    // Paths matching rules
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isValidCategory(request.resource.data);
      allow delete: if true;
    }

    match /prompts/{promptId} {
      allow read: if true;
      allow create, update: if isValidPrompt(request.resource.data);
      allow delete: if true;
    }

    match /phdRecords/{recordId} {
      allow read: if true;
      allow create, update: if isValidMedicalRecord(request.resource.data);
      allow delete: if true;
    }
  }
}
